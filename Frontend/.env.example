# Used only at build time on Vercel (npm run build → writes config.js).
# Do NOT put APP_PASSWORD here — the password lives on the Backend (.env / Render).
#
# Local development does not need this file: app.js falls back to http://127.0.0.1:8000.
#
# On Vercel → Project Settings → Environment Variables, set:
RESUMEFORGE_API_BASE=https://YOUR-SERVICE.onrender.com
