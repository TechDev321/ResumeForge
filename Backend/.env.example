# Copy this file to Backend/.env and fill in values.
# Never commit .env (it may contain secrets).

# --- Required ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Password gate for the site (also set this on Render).
# Leave empty to disable auth (open access).
APP_PASSWORD=change-me

# Comma-separated browser origins allowed to call the API (no trailing slash).
# Local example + your Vercel URL for production.
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://YOUR-FRONTEND.vercel.app

# --- Optional ---
# Separate secret used to sign session tokens after login (defaults to APP_PASSWORD).
# APP_AUTH_SECRET=

# Paths relative to Backend/ unless absolute
# RESUME_TEMPLATE=corey_resume_template(Nielsen_Disney_TCS).docx
# RESUME_PROMPT=Resume Prompt.txt
# COVER_LETTER_TEMPLATE=corey_cover_letter_template.docx
# COVER_LETTER_PROMPT=Cover Letter Prompt.txt
# QUESTION_PROMPT=Question_prompt.txt

# Disk caches (0=off recommended on Render free tier)
RESUME_CACHE=0
COVER_LETTER_CACHE=0
QUESTION_CACHE=0

# Optional: force person name used in downloaded filenames
# RESUME_PERSON_NAME=Corey_Joel_Deloach
