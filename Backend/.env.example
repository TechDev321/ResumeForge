# Copy to .env and fill in values. Never commit .env.

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Comma-separated browser origins allowed to call the API.
# Use * for local smoke tests; lock this down on Render.
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,https://YOUR-FRONTEND.vercel.app

# Optional overrides (paths relative to Backend/ unless absolute)
# RESUME_TEMPLATE=corey_resume_template(Nielsen_Disney_TCS).docx
# RESUME_PROMPT=Resume Prompt.txt

# Disk cache for identical JD regenerations (0=off on Render by default)
RESUME_CACHE=0

# Optional: force person name used in downloaded filenames
# RESUME_PERSON_NAME=Corey_Joel_Deloach
